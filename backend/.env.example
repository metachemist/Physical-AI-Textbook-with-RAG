# Neon Serverless Postgres — connection string for asyncpg
DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# Qdrant Cloud — cluster URL and API key
QDRANT_URL=https://<cluster-id>.cloud.qdrant.io
QDRANT_API_KEY=<key>
QDRANT_COLLECTION=physical_ai_textbook

# OpenRouter — API key and target LLM model
OPENROUTER_API_KEY=<key>
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Embedding — local sentence-transformers model name
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Better-Auth microservice (Phase 3)
BETTER_AUTH_SECRET=<secret>
AUTH_SERVICE_URL=http://localhost:3001

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://<github-pages-url>
